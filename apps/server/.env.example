SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_GYM_PHOTO_BUCKET="gym-photos"
SESSION_COOKIE_SECRET="replace-with-a-long-random-secret"

# Origin of the web app for CORS, e.g. http://localhost:8080
FRONTEND_URL="http://localhost:8080"

# Rate limiting
# Set TRUST_PROXY when running behind a reverse proxy/load balancer so req.ip is correct.
TRUST_PROXY="false"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="300"
AUTH_RATE_LIMIT_WINDOW_MS="900000"
AUTH_RATE_LIMIT_MAX_REQUESTS="20"

# Optional Twilio WhatsApp configuration
# TWILIO_ACCOUNT_SID="your_twilio_account_sid"
# TWILIO_AUTH_TOKEN="your_twilio_auth_token"
# TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
