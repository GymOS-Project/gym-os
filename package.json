{
  "name": "gym-member-hub",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.14",
  "engines": {
    "bun": ">=1.3.14",
    "node": ">=18"
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:web": "turbo dev --filter=web",
    "dev:server": "turbo dev --filter=server",
    "build": "turbo build",
    "lint": "turbo lint",
    "prepare": "husky"
  },
  "workspaces": [
    "apps/*"
  ],
  "devDependencies": {
    "husky": "^9.1.7",
    "turbo": "^2.3.3"
  }
}
